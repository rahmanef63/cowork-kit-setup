# Purpose: example environment for the webapp. Copy to `.env.local` and fill in.
# `npx convex dev` writes this value automatically the first time you run it.
NEXT_PUBLIC_CONVEX_URL=

# NOTE: There is intentionally no ANTHROPIC_API_KEY here.
# This app is BYOK (bring your own key): each user pastes their own Anthropic
# key in the UI and it is stored per anonymous session in Convex. Never ship a
# server-side Anthropic key with this template.
